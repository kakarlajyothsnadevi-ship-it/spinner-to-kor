# SkillBloom environment variables
#
# The app runs fully without any of these — the AI tutor falls back to a built-in
# offline tutor when no key is present. Add a key to enable the real AI tutor.

# Anthropic API key — powers the Live AI Classroom chat (server-side only).
# Get one at https://console.anthropic.com/ , then copy this file to `.env.local`.
ANTHROPIC_API_KEY=
